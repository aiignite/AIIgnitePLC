{
  "name": "aiignite-plc-backend",
  "version": "1.0.0",
  "description": "Backend API for AIIgnitePLC - Web-based PLC Programming Tool",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "db:migrate": "psql -h localhost -U postgres -d aiignite_plc -f migrations/001_initial_schema.sql",
    "db:reset": "psql -h localhost -U postgres -d aiignite_plc -c 'DROP SCHEMA public CASCADE; CREATE SCHEMA public;' && npm run db:migrate"
  },
  "keywords": [
    "plc",
    "automation",
    "siemens",
    "ladder-logic"
  ],
  "author": "AIIgnite Team",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^8.4.0",
    "@fastify/websocket": "^10.0.0",
    "@google/generative-ai": "^0.1.3",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "fastify": "^4.25.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.0",
    "uuid": "^9.0.0",
    "ws": "^8.14.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
