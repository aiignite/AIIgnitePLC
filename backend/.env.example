# 服务器配置
PORT=3310
HOST=0.0.0.0
NODE_ENV=development

# 数据库配置（本地开发默认值）
# Docker 部署时使用 localhost:5433（映射到容器内 5432）
# 本地 PostgreSQL 直接连接时使用 localhost:5432
DB_HOST=localhost
DB_PORT=5433
DB_NAME=aiignite_plc
DB_USER=postgres
DB_PASSWORD=postgres

# CORS 配置（本地前端地址）
CORS_ORIGIN=http://localhost:3300

# JWT 配置（如需认证）
JWT_SECRET=aiignite-plc-secret-key
JWT_EXPIRES_IN=7d

# AI API 配置
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
AI_MODEL=gemini-pro

# WebSocket 配置
WS_HEARTBEAT=30000

# 日志级别
LOG_LEVEL=info
